---
interface Props {
  items: { label: string; value: string }[];
}

const { items } = Astro.props;
---

<dl class="metadata-row surface-card">
  {items.map((item) => (
    <div>
      <dt>{item.label}</dt>
      <dd>{item.value}</dd>
    </div>
  ))}
</dl>

<style>
  .metadata-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
    gap: 1rem;
    padding: 1rem 1.1rem;
    margin: 1.5rem 0;
    text-align: start;
  }

  .metadata-row dt {
    color: var(--text-faint);
    font-size: 0.84rem;
  }

  .metadata-row dd {
    margin: 0.2rem 0 0;
    font-weight: 600;
  }

  @media (max-width: 640px) {
    .metadata-row {
      grid-template-columns: 1fr;
      gap: 0.75rem;
      padding: 0.9rem 1rem;
    }

    .metadata-row > div {
      padding-top: 0.75rem;
      border-top: 1px solid var(--line);
    }

    .metadata-row > div:first-child {
      padding-top: 0;
      border-top: 0;
    }
  }
</style>
