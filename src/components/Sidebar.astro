---
import { allPages } from "../data/site";
import { withBase } from "../data/paths";
---

<div class="sidebar-backdrop" data-backdrop hidden></div>
<aside id="site-sidebar" class="site-sidebar" aria-label="التنقل الكامل" data-sidebar>
  <div class="sidebar-head">
    <p class="eyebrow">دليل كامل</p>
    <button type="button" class="sidebar-close" aria-label="إغلاق القائمة" data-menu-close>×</button>
  </div>
  <div class="sidebar-body">
    {Array.from(new Set(allPages.map((item) => item.category))).map((group) => (
      <section>
        <h2>{group}</h2>
        <ul>
          {allPages
            .filter((item) => item.category === group)
            .map((item) => (
              <li>
                <a href={withBase(item.href)}>
                  <strong>{item.label}</strong>
                  <span>{item.description}</span>
                </a>
              </li>
            ))}
        </ul>
      </section>
    ))}
  </div>
</aside>

<script is:inline>
  const sidebar = document.querySelector("[data-sidebar]");
  const backdrop = document.querySelector("[data-backdrop]");
  const openButton = document.querySelector("[data-menu-toggle]");
  const closeButton = document.querySelector("[data-menu-close]");

  const setMenu = (open) => {
    if (!sidebar || !backdrop || !openButton) return;
    sidebar.dataset.open = String(open);
    backdrop.hidden = !open;
    document.body.classList.toggle("menu-open", open);
    openButton.setAttribute("aria-expanded", String(open));
  };

  openButton?.addEventListener("click", () => setMenu(true));
  closeButton?.addEventListener("click", () => setMenu(false));
  backdrop?.addEventListener("click", () => setMenu(false));
  window.addEventListener("keydown", (event) => {
    if (event.key === "Escape") setMenu(false);
  });
</script>

<style>
  .sidebar-backdrop {
    position: fixed;
    inset: 0;
    z-index: 24;
    background: rgba(31, 38, 35, 0.36);
  }

  .site-sidebar {
    position: fixed;
    inset-block: 0;
    inset-inline-end: 0;
    z-index: 25;
    width: min(24rem, 100vw);
    padding: 1rem;
    background: rgba(251, 248, 243, 0.96);
    border-inline-start: 1px solid var(--line);
    transform: translateX(100%);
    transition: transform 0.24s ease;
    overflow-y: auto;
  }

  .site-sidebar[data-open="true"] {
    transform: translateX(0);
  }

  .sidebar-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .sidebar-close {
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: transparent;
    font-size: 1.5rem;
    line-height: 1;
  }

  .sidebar-body {
    display: grid;
    gap: 1.4rem;
  }

  .sidebar-body section {
    display: grid;
    gap: 0.7rem;
  }

  .sidebar-body h2 {
    font-size: 1rem;
    font-family: var(--font-sans);
    color: var(--text-soft);
  }

  .sidebar-body ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.55rem;
  }

  .sidebar-body a {
    display: grid;
    gap: 0.22rem;
    padding: 0.95rem 1rem;
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.76);
    border: 1px solid var(--line);
    text-decoration: none;
    text-align: start;
  }

  .sidebar-body span {
    color: var(--text-soft);
    font-size: 0.92rem;
  }

  @media (min-width: 921px) {
    .sidebar-backdrop,
    .site-sidebar {
      display: none;
    }
  }

  @media (max-width: 520px) {
    .site-sidebar {
      width: 100vw;
      padding: 0.85rem;
    }

    .sidebar-body {
      gap: 1rem;
    }

    .sidebar-body a {
      padding: 0.85rem 0.9rem;
    }

    .sidebar-body span {
      font-size: 0.86rem;
    }
  }
</style>
