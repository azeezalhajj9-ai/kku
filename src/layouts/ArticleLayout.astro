---
import BaseLayout from "./BaseLayout.astro";
import PageShell from "../components/PageShell.astro";
import MetadataRow from "../components/MetadataRow.astro";
import { withBase } from "../data/paths";

interface Props {
  title: string;
  description: string;
  summary: string;
  breadcrumbs: { href: string; label: string }[];
  toc?: { href: string; label: string }[];
  metadata: { label: string; value: string }[];
}

const { title, description, summary, breadcrumbs, toc = [], metadata } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <PageShell>
    <section class="section-spacing">
      <div class="container article-layout">
        <div class="article-main">
          <nav class="breadcrumbs" aria-label="مسار التنقل">
            {breadcrumbs.map((item, index) => (
              <>
                <a href={withBase(item.href)}>{item.label}</a>
                {index < breadcrumbs.length - 1 && <span>/</span>}
              </>
            ))}
          </nav>
          <h1>{title}</h1>
          <p class="lede">{summary}</p>
          <MetadataRow items={metadata} />
          <div class="article-prose">
            <slot />
          </div>
        </div>
        {toc.length > 0 && (
          <aside class="article-toc surface-card">
            <strong>في هذه الصفحة</strong>
            <ul>
              {toc.map((item) => (
                <li><a href={item.href}>{item.label}</a></li>
              ))}
            </ul>
          </aside>
        )}
      </div>
    </section>
  </PageShell>
</BaseLayout>

<style>
  .article-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 260px;
    gap: 1.5rem;
    align-items: start;
  }

  .article-main {
    min-width: 0;
  }

  .breadcrumbs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-bottom: 1rem;
    color: var(--text-faint);
    align-items: center;
  }

  .breadcrumbs a {
    text-decoration: none;
  }

  .breadcrumbs span {
    opacity: 0.7;
  }

  .article-toc {
    position: sticky;
    top: 6rem;
    padding: 1rem;
    text-align: start;
  }

  .article-toc strong {
    display: block;
    margin-bottom: 0.75rem;
  }

  .article-toc ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.6rem;
  }

  .article-toc a {
    color: var(--text-soft);
    text-decoration: none;
  }

  @media (max-width: 980px) {
    .article-layout {
      grid-template-columns: 1fr;
    }

    .article-toc {
      position: static;
      order: 2;
    }
  }

  @media (max-width: 640px) {
    .breadcrumbs {
      font-size: 0.9rem;
      gap: 0.3rem;
    }

    .article-toc {
      padding: 0.9rem;
      border-radius: 18px;
    }
  }
</style>
