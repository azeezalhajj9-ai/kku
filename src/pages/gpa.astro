---
import ArticleLayout from "../layouts/ArticleLayout.astro";
import Callout from "../components/Callout.astro";
---

<ArticleLayout
  title="حساب المعدل الفصلي"
  description="حاسبة سريعة للمعدل الفصلي من 5 مع تنظيم أوضح للمواد والساعات والتقديرات."
  summary="أعدنا بناء نموذج المعدل الفصلي ليكون أوضح على الجوال وأسهل في إدخال المواد ومراجعة النتيجة بشكل مباشر."
  breadcrumbs={[
    { href: "/", label: "الرئيسية" },
    { href: "/tools", label: "الأدوات" },
    { href: "/gpa", label: "المعدل الفصلي" }
  ]}
  metadata={[
    { label: "التصنيف", value: "أداة حسابية" },
    { label: "المقياس", value: "من 5" },
    { label: "آخر مراجعة", value: "21 أبريل 2026" }
  ]}
>
  <Callout title="طريقة الاستخدام">
    أضف كل مادة مع عدد ساعاتها والتقدير النهائي لها، وستحسب الصفحة مجموع الساعات والنقاط والمعدل
    الفصلي والتقدير التقريبي بشكل مباشر.
  </Callout>

  <section class="surface-card calculator-panel">
    <div class="calculator-head">
      <div>
        <h2>مواد الفصل</h2>
        <p class="muted calculator-copy">
          أدخل اسم المادة إن أردت، ثم الساعات والتقدير. النموذج مرتب ليعمل بشكل واضح في الواجهة
          العربية وعلى الشاشات الصغيرة.
        </p>
      </div>
      <div class="calculator-actions">
        <button id="reset-courses" class="button button-secondary" type="button">إعادة التهيئة</button>
        <button id="add-course" class="button button-secondary" type="button">إضافة مادة</button>
      </div>
    </div>

    <div id="course-list" class="course-list"></div>
  </section>

  <section class="surface-card result-panel" aria-label="نتيجة الحساب">
    <div>
      <span class="badge">المعدل الفصلي</span>
      <p id="gpa-result" class="result-value">0.000</p>
    </div>
    <div>
      <span class="badge">عدد الساعات</span>
      <p id="hours-result" class="result-value">0</p>
    </div>
    <div>
      <span class="badge">مجموع النقاط</span>
      <p id="points-result" class="result-value">0.000</p>
    </div>
    <div>
      <span class="badge">التقدير التقريبي</span>
      <p id="rating-result" class="result-value">-</p>
    </div>
  </section>

  <script is:inline>
    const gradeMap = {
      "A+": 5,
      A: 4.75,
      "B+": 4.5,
      B: 4,
      "C+": 3.5,
      C: 3,
      "D+": 2.5,
      D: 2,
      F: 1
    };

    const ratings = [
      { min: 4.5, label: "ممتاز" },
      { min: 3.75, label: "جيد جدا" },
      { min: 2.75, label: "جيد" },
      { min: 2, label: "مقبول" },
      { min: 0, label: "متعثر" }
    ];

    const list = document.querySelector("#course-list");
    const addButton = document.querySelector("#add-course");
    const resetButton = document.querySelector("#reset-courses");
    const gpaResult = document.querySelector("#gpa-result");
    const hoursResult = document.querySelector("#hours-result");
    const pointsResult = document.querySelector("#points-result");
    const ratingResult = document.querySelector("#rating-result");

    const bindCourseEvents = (row) => {
      row.querySelector(".remove-course")?.addEventListener("click", () => {
        row.remove();
        renumberCourses();
        calculate();
      });

      row.querySelectorAll("input, select").forEach((field) => {
        field.addEventListener("input", calculate);
        field.addEventListener("change", calculate);
      });
    };

    const courseTemplate = () => {
      const courseNumber = list.children.length + 1;
      const row = document.createElement("div");
      row.className = "course-row";
      row.innerHTML = `
        <div class="course-row-head">
          <div class="course-row-title">
            <span class="course-index">${courseNumber}</span>
            <strong>مادة ${courseNumber}</strong>
          </div>
          <button type="button" class="remove-course">حذف</button>
        </div>
        <div class="course-fields">
          <label class="course-field course-name">
            <span>اسم المادة</span>
            <input type="text" class="course-title" placeholder="اختياري" />
          </label>
          <label class="course-field">
            <span>الساعات</span>
            <input type="number" min="0" step="1" value="3" class="course-hours" inputmode="numeric" />
          </label>
          <label class="course-field">
            <span>التقدير</span>
            <select class="course-grade">
              <option value="A+">A+ | ممتاز مرتفع | 5.00</option>
              <option value="A">A | ممتاز | 4.75</option>
              <option value="B+">B+ | جيد جدا مرتفع | 4.50</option>
              <option value="B" selected>B | جيد جدا | 4.00</option>
              <option value="C+">C+ | جيد مرتفع | 3.50</option>
              <option value="C">C | جيد | 3.00</option>
              <option value="D+">D+ | مقبول مرتفع | 2.50</option>
              <option value="D">D | مقبول | 2.00</option>
              <option value="F">F | متعثر | 1.00</option>
            </select>
          </label>
        </div>
      `;

      bindCourseEvents(row);
      return row;
    };

    const renumberCourses = () => {
      document.querySelectorAll(".course-row").forEach((row, index) => {
        const number = index + 1;
        const badge = row.querySelector(".course-index");
        const label = row.querySelector(".course-row-head strong");

        if (badge) badge.textContent = String(number);
        if (label) label.textContent = `مادة ${number}`;
      });
    };

    const seedCourses = (count = 4) => {
      list.innerHTML = "";

      for (let i = 0; i < count; i += 1) {
        list.appendChild(courseTemplate());
      }

      renumberCourses();
      calculate();
    };

    const calculate = () => {
      let totalHours = 0;
      let totalPoints = 0;

      document.querySelectorAll(".course-row").forEach((row) => {
        const hours = Number(row.querySelector(".course-hours")?.value || 0);
        const grade = row.querySelector(".course-grade")?.value ?? "B";

        totalHours += hours;
        totalPoints += hours * gradeMap[grade];
      });

      const gpa = totalHours > 0 ? totalPoints / totalHours : 0;
      gpaResult.textContent = gpa.toFixed(3);
      hoursResult.textContent = String(totalHours);
      pointsResult.textContent = totalPoints.toFixed(3);
      ratingResult.textContent = ratings.find((item) => gpa >= item.min)?.label ?? "-";
    };

    addButton?.addEventListener("click", () => {
      list.appendChild(courseTemplate());
      renumberCourses();
      calculate();
    });

    resetButton?.addEventListener("click", () => {
      seedCourses();
    });

    seedCourses();
  </script>
</ArticleLayout>

<style>
  .calculator-panel,
  .result-panel {
    padding: 1.25rem;
  }

  .calculator-head {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .calculator-copy {
    margin-top: 0.5rem;
    max-width: 62ch;
  }

  .calculator-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .course-list {
    display: grid;
    gap: 0.9rem;
  }

  .course-row {
    display: grid;
    gap: 1rem;
    padding: 1rem 1rem 1.1rem;
    border: 1px solid var(--line);
    border-radius: 20px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(252, 250, 246, 0.86));
    box-shadow: 0 10px 30px rgba(43, 41, 36, 0.05);
  }

  .course-row-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 0.95rem;
    border-bottom: 1px solid rgba(94, 88, 76, 0.12);
  }

  .course-row-title {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 0;
  }

  .course-index {
    display: inline-grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    background: rgba(59, 78, 60, 0.1);
    color: var(--accent);
    font-size: 0.92rem;
    font-weight: 700;
    flex: 0 0 auto;
  }

  .course-row-head strong {
    font-size: 1rem;
    line-height: 1.3;
  }

  .remove-course {
    width: fit-content;
    min-height: 2.75rem;
    border: 1px solid rgba(141, 74, 58, 0.2);
    padding: 0.55rem 0.8rem;
    border-radius: 999px;
    background: rgba(141, 74, 58, 0.06);
    color: #8d4a3a;
    font: inherit;
    font-weight: 600;
    cursor: pointer;
  }

  .course-fields {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(120px, 0.6fr) minmax(220px, 1fr);
    gap: 0.9rem;
    align-items: end;
  }

  .course-field {
    display: grid;
    gap: 0.35rem;
  }

  .course-field span {
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--muted);
  }

  .course-name {
    min-width: 0;
  }

  .course-row input,
  .course-row select {
    width: 100%;
    min-height: 3rem;
    padding: 0.75rem 0.9rem;
    border: 1px solid var(--line);
    border-radius: 14px;
    background: var(--surface);
    font: inherit;
  }

  .result-panel {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-top: 1rem;
  }

  .result-value {
    margin-top: 0.7rem;
    font-size: 1.6rem;
    font-weight: 700;
  }

  @media (max-width: 860px) {
    .calculator-head,
    .result-panel {
      grid-template-columns: 1fr;
    }

    .course-fields {
      grid-template-columns: 1fr 1fr;
    }

    .course-name {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 520px) {
    .calculator-actions {
      display: grid;
      grid-template-columns: 1fr;
      width: 100%;
    }

    .calculator-actions .button {
      width: 100%;
    }

    .course-row {
      padding: 0.9rem;
    }

    .course-row-head {
      flex-direction: column;
      align-items: stretch;
    }

    .course-fields {
      grid-template-columns: 1fr;
    }

    .course-row-title,
    .remove-course {
      width: 100%;
    }

    .remove-course {
      text-align: center;
    }
  }
</style>
