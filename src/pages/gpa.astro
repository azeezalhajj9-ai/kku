---
import ArticleLayout from "../layouts/ArticleLayout.astro";
import Callout from "../components/Callout.astro";
---

<ArticleLayout
  title="حساب المعدل الفصلي"
  description="حاسبة خفيفة للمعدل الفصلي من 5 مع إجمالي النقاط والساعات."
  summary="أعيد تصميم الحاسبة لتصبح أسهل على الجوال وأكثر وضوحاً في ترتيب المدخلات والنتائج، مع الحفاظ على وظيفة الصفحة الأصلية."
  breadcrumbs={[
    { href: "/", label: "الرئيسية" },
    { href: "/tools", label: "الأدوات" },
    { href: "/gpa", label: "المعدل الفصلي" }
  ]}
  metadata={[
    { label: "التصنيف", value: "أداة حسابية" },
    { label: "المقياس", value: "من 5" },
    { label: "آخر مراجعة", value: "21 أبريل 2026" }
  ]}
>
  <Callout title="طريقة الاستخدام">
    أضف كل مادة بساعاتها وتقديرها، ثم ستحسب الصفحة مجموع الساعات والنقاط والمعدل التقريبي والتقدير العام بشكل مباشر.
  </Callout>

  <section class="surface-card calculator-panel">
    <div class="calculator-head">
      <div>
        <h2>مواد الفصل</h2>
        <p class="muted calculator-copy">أدخل ساعات كل مادة والتقدير النهائي لها، ويمكنك كتابة اسم المادة لسهولة التتبع.</p>
      </div>
      <div class="calculator-actions">
        <button id="reset-courses" class="button button-secondary" type="button">إعادة التهيئة</button>
        <button id="add-course" class="button button-secondary" type="button">إضافة مادة</button>
      </div>
    </div>
    <div id="course-list" class="course-list"></div>
  </section>

  <section class="surface-card result-panel">
    <div>
      <span class="badge">المعدل الفصلي</span>
      <p id="gpa-result" class="result-value">0.000</p>
    </div>
    <div>
      <span class="badge">عدد الساعات</span>
      <p id="hours-result" class="result-value">0</p>
    </div>
    <div>
      <span class="badge">مجموع النقاط</span>
      <p id="points-result" class="result-value">0.000</p>
    </div>
    <div>
      <span class="badge">التقدير التقريبي</span>
      <p id="rating-result" class="result-value">-</p>
    </div>
  </section>

  <script is:inline>
    const gradeMap = {
      "A+": 5,
      A: 4.75,
      "B+": 4.5,
      B: 4,
      "C+": 3.5,
      C: 3,
      "D+": 2.5,
      D: 2,
      F: 1
    };

    const ratings = [
      { min: 4.5, label: "ممتاز" },
      { min: 3.75, label: "جيد جداً" },
      { min: 2.75, label: "جيد" },
      { min: 2, label: "مقبول" },
      { min: 0, label: "متعثر" }
    ];

    const list = document.querySelector("#course-list");
    const addButton = document.querySelector("#add-course");
    const resetButton = document.querySelector("#reset-courses");
    const gpaResult = document.querySelector("#gpa-result");
    const hoursResult = document.querySelector("#hours-result");
    const pointsResult = document.querySelector("#points-result");
    const ratingResult = document.querySelector("#rating-result");

    const courseTemplate = () => {
      const courseNumber = list.children.length + 1;
      const row = document.createElement("div");
      row.className = "course-row";
      row.innerHTML = `
        <div class="course-row-head">
          <strong>مادة ${courseNumber}</strong>
          <button type="button" class="remove-course">حذف</button>
        </div>
        <label class="course-field course-name">
          <span>اسم المادة</span>
          <input type="text" class="course-title" placeholder="اختياري" />
        </label>
        <label class="course-field">
          <span>الساعات</span>
          <input type="number" min="0" step="1" value="3" class="course-hours" />
        </label>
        <label class="course-field">
          <span>التقدير</span>
          <select class="course-grade">
            <option value="A+">A+ | ممتاز مرتفع | 5.00</option>
            <option value="A">A | ممتاز | 4.75</option>
            <option value="B+">B+ | جيد جداً مرتفع | 4.50</option>
            <option value="B" selected>B | جيد جداً | 4.00</option>
            <option value="C+">C+ | جيد مرتفع | 3.50</option>
            <option value="C">C | جيد | 3.00</option>
            <option value="D+">D+ | مقبول مرتفع | 2.50</option>
            <option value="D">D | مقبول | 2.00</option>
            <option value="F">F | متعثر | 1.00</option>
          </select>
        </label>
      `;
      row.querySelector(".remove-course").addEventListener("click", () => {
        row.remove();
        renumberCourses();
        calculate();
      });
      row.querySelectorAll("input, select").forEach((el) => el.addEventListener("input", calculate));
      return row;
    };

    const renumberCourses = () => {
      document.querySelectorAll(".course-row").forEach((row, index) => {
        const label = row.querySelector(".course-row-head strong");
        if (label) label.textContent = `مادة ${index + 1}`;
      });
    };

    const seedCourses = (count = 4) => {
      list.innerHTML = "";
      for (let i = 0; i < count; i += 1) list.appendChild(courseTemplate());
      renumberCourses();
      calculate();
    };

    const calculate = () => {
      let totalHours = 0;
      let totalPoints = 0;
      document.querySelectorAll(".course-row").forEach((row) => {
        const hours = Number(row.querySelector(".course-hours").value || 0);
        const grade = row.querySelector(".course-grade").value;
        totalHours += hours;
        totalPoints += hours * gradeMap[grade];
      });

      const gpa = totalHours ? totalPoints / totalHours : 0;
      gpaResult.textContent = gpa.toFixed(3);
      hoursResult.textContent = String(totalHours);
      pointsResult.textContent = totalPoints.toFixed(3);
      ratingResult.textContent = ratings.find((item) => gpa >= item.min)?.label ?? "-";
    };

    addButton?.addEventListener("click", () => {
      list.appendChild(courseTemplate());
      renumberCourses();
      calculate();
    });

    resetButton?.addEventListener("click", () => seedCourses());

    seedCourses();
  </script>
</ArticleLayout>

<style>
  .calculator-panel,
  .result-panel {
    padding: 1.25rem;
  }

  .calculator-head {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .calculator-copy {
    margin-top: 0.5rem;
  }

  .calculator-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .course-list {
    display: grid;
    gap: 0.8rem;
  }

  .course-row {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) 140px minmax(240px, 1fr);
    gap: 0.9rem;
    padding: 1rem;
    border: 1px solid var(--line);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.7);
    align-items: end;
  }

  .course-row-head {
    display: grid;
    gap: 0.55rem;
    align-self: stretch;
    align-content: space-between;
  }

  .course-row-head strong {
    font-size: 1rem;
  }

  .remove-course {
    width: fit-content;
    border: 0;
    padding: 0;
    background: none;
    color: #8d4a3a;
    font-weight: 600;
    cursor: pointer;
  }

  .course-field {
    display: grid;
    gap: 0.35rem;
  }

  .course-name {
    min-width: 0;
  }

  .course-row input,
  .course-row select {
    min-height: 3rem;
    padding: 0.75rem 0.9rem;
    border: 1px solid var(--line);
    border-radius: 14px;
    background: var(--surface);
  }

  .result-panel {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-top: 1rem;
  }

  .result-value {
    font-size: 1.6rem;
    font-weight: 700;
    margin-top: 0.7rem;
  }

  @media (max-width: 860px) {
    .calculator-head,
    .course-row,
    .result-panel {
      grid-template-columns: 1fr;
    }

    .course-row-head {
      align-content: start;
    }
  }

  @media (max-width: 520px) {
    .calculator-actions {
      display: grid;
      grid-template-columns: 1fr;
      width: 100%;
    }

    .calculator-actions .button {
      width: 100%;
    }

    .course-row {
      padding: 0.9rem;
    }
  }
</style>
